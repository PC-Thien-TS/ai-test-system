{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Domain Regression Suite",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "feature",
    "regression_ids",
    "notes"
  ],
  "properties": {
    "feature": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "name"
      ],
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "regression_ids": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "pattern": "^TC-[A-Z0-9-]+-[0-9]{3}$"
      }
    },
    "notes": {
      "type": "string",
      "minLength": 1
    }
  }
}
