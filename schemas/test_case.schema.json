{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Domain Test Case Suite",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "feature",
    "testcases"
  ],
  "properties": {
    "feature": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "name",
        "scope"
      ],
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1
        },
        "scope": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "testcases": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "id",
          "title",
          "preconditions",
          "steps",
          "expected",
          "priority",
          "type",
          "tags",
          "notes"
        ],
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^TC-[A-Z0-9-]+-[0-9]{3}$"
          },
          "title": {
            "type": "string",
            "minLength": 1
          },
          "preconditions": {
            "type": "array",
            "items": {
              "type": "string",
              "minLength": 1
            }
          },
          "steps": {
            "type": "array",
            "minItems": 3,
            "maxItems": 8,
            "items": {
              "type": "string",
              "minLength": 1
            }
          },
          "expected": {
            "type": "array",
            "minItems": 1,
            "maxItems": 4,
            "items": {
              "type": "string",
              "minLength": 1
            }
          },
          "priority": {
            "type": "string",
            "enum": [
              "P0",
              "P1",
              "P2",
              "P3"
            ]
          },
          "type": {
            "type": "string",
            "enum": [
              "smoke",
              "regression"
            ]
          },
          "tags": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string",
              "minLength": 1
            }
          },
          "notes": {
            "type": "string"
          }
        }
      }
    }
  }
}
